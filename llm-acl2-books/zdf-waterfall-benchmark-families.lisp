; zdf-waterfall-benchmark-families.lisp
;
; A first replayable benchmark for finite proof-plan search.  The benchmark
; records the actual PROVE$ receipt generated by ZDD, extends the ambient
; logical world with unrelated rewrite rules, reruns the same finite search,
; and checks that the narrow semantic-interface plan remains selected with a
; small waterfall proof.

(in-package "ACL2")

(include-book "zdd-waterfall-plan-search")
(include-book "xdoc/top" :dir :system)

(defxdoc zdf-waterfall-benchmark-families
  :parents (zdd-waterfall-plan-search)
  :short "Replayable waterfall benchmarks with receipts and extension tests."
  :long
  "<p>This book turns the live proof search in
  <tt>ZDD-WATERFALL-PLAN-SEARCH</tt> into logical benchmark data.  The first
  receipt records that an empty theory failed and that a narrow semantic
  interface proved the fold/append theorem.  The book then introduces an
  unrelated family of enabled rewrite rules and repeats the search under a
  fresh theorem name.</p>

  <p>The benchmark does not trust the recorded step count as evidence that a
  theorem is true.  Each successful search is followed by an ordinary
  <tt>DEFTHM</tt>.  Receipts measure search behavior; ACL2's normal event
  admission supplies soundness.</p>")

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 1. Reify a table receipt as a logical constant
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defun wfb-table-receipt (name state)
  (declare (xargs :mode :program :stobjs state))
  (let ((entry (assoc-eq name
                         (table-alist 'wps-proof-receipts (w state)))))
    (value (cdr entry))))

(defmacro wfb-capture-receipt (constant theorem-name)
  `(make-event
    (mv-let (erp receipt state)
      (wfb-table-receipt ',theorem-name state)
      (cond (erp (mv erp nil state))
            ((not (wps-search-receiptp receipt))
             (er soft 'wfb-capture-receipt
                 "No well-formed waterfall receipt exists for ~x0."
                 ',theorem-name))
            (t (value (list 'defconst ',constant
                            (list 'quote receipt))))))))

(wfb-capture-receipt *wfb-baseline-receipt* wps-fold-of-append)

(defun wfb-failure-name (failure)
  (symbol-fix (car failure)))

(defun wfb-failure-kind (failure)
  (cadr failure))

(defun wfb-failure-steps (failure)
  (ifix (caddr failure)))

(defun wfb-one-failed-empty-plan-p (failures)
  (and (consp failures)
       (endp (cdr failures))
       (eq (wfb-failure-name (car failures)) 'empty-plan)
       (eq (wfb-failure-kind (car failures)) :proof-failure)
       (natp (wfb-failure-steps (car failures)))))

(defun wfb-small-success-receiptp (receipt step-cap)
  (and (wps-search-receiptp receipt)
       (eq (wps-receipt-selected-name receipt) 'fold-induction-plan)
       (wfb-one-failed-empty-plan-p (wps-receipt-failures receipt))
       (natp (wps-receipt-steps receipt))
       (< (wps-receipt-steps receipt) (nfix step-cap))))

(assert-event
 (wfb-small-success-receiptp *wfb-baseline-receipt* 100))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 2. Add an unrelated enabled theory extension
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defun wfb-noise-map (xs)
  (if (endp xs)
      nil
    (cons (car xs) (wfb-noise-map (cdr xs)))))

(defun wfb-noise-pair (x)
  (cons x x))

(defthm wfb-noise-map-identity
  (equal (wfb-noise-map xs) (list-fix xs)))

(defthm wfb-noise-pair-car
  (equal (car (wfb-noise-pair x)) x))

(defthm wfb-noise-pair-cdr
  (equal (cdr (wfb-noise-pair x)) x))

(defthm wfb-noise-map-of-append
  (equal (wfb-noise-map (append x y))
         (append (wfb-noise-map x)
                 (wfb-noise-map y))))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 3. Repeat the same finite search after the extension
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(wps-defthm
 wfb-fold-of-append-under-extension
 (equal (wps-fold (append x y))
        (+ (wps-fold x) (wps-fold y)))
 ((empty-plan
   ((:theory empty-theory
             nil (empty-theory-tried)
             (1 0 5 0 1)))
   (("Goal" :in-theory nil)))
  (fold-induction-plan
   ((:theory fold-and-append
             nil (definitions-open)
             (0 1 80 2 0))
    (:induct fold-on-x
             (definitions-open) (goal-closed)
             (0 2 140 0 0)))
   (("Goal"
     :in-theory (theory 'wps-fold-semantic-interface)))))
 :step-limit 1000)

(wfb-capture-receipt *wfb-extension-receipt*
                     wfb-fold-of-append-under-extension)

(assert-event
 (wfb-small-success-receiptp *wfb-extension-receipt* 100))

(assert-event
 (equal (wps-receipt-selected-name *wfb-baseline-receipt*)
        (wps-receipt-selected-name *wfb-extension-receipt*)))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 4. Logical benchmark summaries
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defun wfb-result (name receipt)
  (list :waterfall-benchmark
        (symbol-fix name)
        (wps-receipt-selected-name receipt)
        (wps-receipt-steps receipt)
        (list-fix (wps-receipt-failures receipt))))

(defun wfb-resultp (result)
  (and (true-listp result)
       (equal (len result) 5)
       (eq (car result) :waterfall-benchmark)
       (symbolp (cadr result))
       (symbolp (caddr result))
       (integerp (cadddr result))
       (true-listp (car (cddddr result)))))

(defconst *wfb-first-family-results*
  (list (wfb-result 'baseline *wfb-baseline-receipt*)
        (wfb-result 'after-unrelated-extension *wfb-extension-receipt*)))

(assert-event
 (and (wfb-resultp (car *wfb-first-family-results*))
      (wfb-resultp (cadr *wfb-first-family-results*))
      (equal (wps-receipt-steps *wfb-baseline-receipt*) 21)
      (equal (wps-receipt-steps *wfb-extension-receipt*) 21)))
